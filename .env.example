# Redis queue (shared with the SAAS backend's BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue name to consume. Must match what the SAAS backend pushes to.
QUEUE_NAME=twitter-actions

# Appium server (local, default port)
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# Android device serial (run `adb devices` to get it). Leave empty to auto-pick the first connected device.
ANDROID_DEVICE_SERIAL=

# X app package on your phone (almost always com.twitter.android)
X_APP_PACKAGE=com.twitter.android
X_APP_ACTIVITY=com.twitter.android.StartActivity

# Optional: the @handle (without leading @) currently active on the device.
# When set, switchAccount() skips the drawer+sheet flow entirely for matching
# jobs. Single-account setups SHOULD set this — it avoids all the UIA2 flake
# points in account switching.
# Example: X_ACTIVE_ACCOUNT=k1lls3vr4q
X_ACTIVE_ACCOUNT=

# Job concurrency. Keep at 1 — a phone can only do one thing at a time.
WORKER_CONCURRENCY=1

# Log level: debug | info | warn | error
LOG_LEVEL=info
